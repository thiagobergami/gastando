{
  "name": "gastando",
  "version": "0.2.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.{js,ts}\"",
    "coverage": "c8 node --import tsx --test \"test/**/*.test.{js,ts}\"",
    "build:css": "tailwindcss -i public/css/tailwind.src.css -o public/css/app.css --minify",
    "watch:css": "tailwindcss -i public/css/tailwind.src.css -o public/css/app.css --watch",
    "build:binaries": "npm run build:css && npm run build && pkg --config package.json dist/server.js",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "migrations/**/*",
      "node_modules/better-sqlite3/build/Release/better_sqlite3.node"
    ],
    "targets": [
      "node22-win-x64",
      "node22-linux-x64",
      "node22-macos-x64",
      "node22-macos-arm64"
    ],
    "outputPath": "dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "express": "^5.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.0",
    "@types/supertest": "^7.2.0",
    "@yao-pkg/pkg": "6.19.0",
    "c8": "^11.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
