{
  "name": "gastando",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test \"test/**/*.test.js\"",
    "coverage": "c8 node --test \"test/**/*.test.js\"",
    "build:css": "tailwindcss -i public/css/tailwind.src.css -o public/css/app.css --minify",
    "watch:css": "tailwindcss -i public/css/tailwind.src.css -o public/css/app.css --watch",
    "build:binaries": "npm run build:css && pkg --config package.json src/server.js"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "migrations/**/*"
    ],
    "targets": [
      "node22-win-x64",
      "node22-linux-x64",
      "node22-macos-x64",
      "node22-macos-arm64"
    ],
    "outputPath": "dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "6.19.0",
    "c8": "^11.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19"
  }
}
